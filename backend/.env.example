# Copy to .env and adjust as needed. The app runs with zero changes for local/demo use.

ENVIRONMENT=development
DEBUG=true

# SQLite by default — zero setup. For production, point at Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/earthshare
DATABASE_URL=sqlite:///./earthshare.db

# REQUIRED to be a strong random value in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-only-insecure-secret-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

CORS_ORIGINS=http://localhost:3000

RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# Optional. Leave blank to use the local rule-based insight generator —
# the app is fully functional without this key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
